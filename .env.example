# Optional override for the Whisper-compatible HTTP endpoint used by the
# server transcription fallback. The app works without these values because
# the browser will auto-download a local Whisper model on first use.
T3_TRANSCRIPTION_WHISPER_URL=http://127.0.0.1:8080

# Optional model hint for Whisper-compatible servers that support it.
T3_TRANSCRIPTION_WHISPER_MODEL=whisper-small

# Optional auth header and token if your local endpoint requires auth.
# T3_TRANSCRIPTION_WHISPER_AUTH_HEADER=Authorization
# T3_TRANSCRIPTION_WHISPER_AUTH_TOKEN=Bearer your-token
