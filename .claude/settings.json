{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/show-diff.sh",
            "statusMessage": "Showing diff…"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/humanize-bash.py",
            "statusMessage": "Translating command…"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory memory-compiler python hooks/session-start.py",
            "timeout": 15,
            "statusMessage": "Loading knowledge base…"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory memory-compiler python hooks/pre-compact.py",
            "timeout": 10,
            "statusMessage": "Capturing context before compaction…"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory memory-compiler python hooks/session-end.py",
            "timeout": 10,
            "statusMessage": "Saving conversation memories…"
          }
        ]
      }
    ]
  }
}
