---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Bird Code",
  description = "Bird Code — Codex, Claude, and Gemini in one desktop app (Cursor and OpenCode chats planned). Folder-scoped threads, work log, diff, and thread terminal. No Bird Code account.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var k = "birdcode-marketing-theme";
        var v = localStorage.getItem(k);
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var dark;
        if (v === "dark") dark = true;
        else if (v === "light") dark = false;
        else dark = prefersDark;
        if (dark) document.documentElement.classList.add("dark");
        else document.documentElement.classList.remove("dark");
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
